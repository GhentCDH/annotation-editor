{
  "name": "annotation-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/annotation-ui/src",
  "projectType": "library",
  "tags": ["scope:annotation", "type:ui", "tech:vue"],
  "targets": {
"build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/annotation-ui",
        "configFile": "packages/annotation-ui/vite.config.mts"
      },
      "configurations": {
        "production": { "mode": "production" },
        "development": { "mode": "development" }
      }
    },
    "watch": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/annotation-ui",
        "configFile": "packages/annotation-ui/vite.config.mts",
        "watch": true,
        "sourcemap": true
      },
      "configurations": {
        "development": { "mode": "development" }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
