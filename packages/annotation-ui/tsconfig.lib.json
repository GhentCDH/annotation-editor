{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/packages/annotation-ui",
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    // This requires tslib
    "skipLibCheck": true,
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
