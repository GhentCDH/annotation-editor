{
  "name": "annotation-preview",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/annotation-preview/src",
  "projectType": "library",
  "tags": ["scope:annotation", "type:ui", "tech:vue", "feature:preview"],
  "targets": {
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        {
          "projects": ["annotation-core", "annotation-ui"],
          "target": "build"
        }
      ],
      "options": {
        "outputPath": "dist/packages/annotation-preview",
        "configFile": "packages/annotation-preview/vite.config.mts"
      },
      "configurations": {
        "production": {
          "mode": "production"
        },
        "development": {
          "mode": "development"
        }
      }
    },
    "watch": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/annotation-preview",
        "configFile": "packages/annotation-preview/vite.config.mts",
        "watch": true,
        "sourcemap": true
      },
      "configurations": {
        "development": {
          "mode": "development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{projectRoot}/coverage/unit"]
    }
  }
}
