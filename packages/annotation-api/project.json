{
  "name": "annotation-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/annotation-api/src",
  "projectType": "library",
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "preserveLocalDependencyProtocols": false,
      "manifestRootsToUpdate": ["{projectRoot}", "dist/{projectRoot}"]
    }
  },
  "tags": ["scope:feature", "scope:api"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/annotation-api",
        "tsConfig": "packages/annotation-api/tsconfig.lib.json",
        "packageJson": "packages/annotation-api/package.json",
        "main": "packages/annotation-api/src/index.ts",
        "assets": ["packages/annotation-api/*.md"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  },
  "implicitDependencies": ["annotation-core"]
}
